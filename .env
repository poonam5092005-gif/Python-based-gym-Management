# Copy this file to `.env` and fill in the real values.
# The app auto-loads .env at startup.

# --- Application ---
APP_NAME=Gym Management & Fitness Analytics System
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
# SQLite (default, zero-config)
DATABASE_URL=sqlite:///./data/gym.db
# MySQL example (uncomment + install mysqlclient/pymysql to use):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/gymdb

# --- Auth / Security ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Default admin bootstrap (created on first startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/gym_system.log
